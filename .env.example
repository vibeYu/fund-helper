# ===================================
# 基金估值助手 - 配置文件
# ===================================
# 复制此文件为 .env 并修改配置

# === 基金列表（逗号分隔） ===
FUND_LIST=161725,110011,110020

# === 基金简称映射（可选，格式: 代码:简称） ===
FUND_ALIASES=161725:白酒,110011:中小盘,110020:易方达

# === 调度配置 ===
# 刷新间隔（秒），用于 interval 模式
REFRESH_INTERVAL=60
# 定时触发时间（逗号分隔），如设置则使用定时模式
# SCHEDULE_TIMES=11:30,14:30

# === 涨跌告警阈值 ===
ALERT_RISE_PCT=2.0
ALERT_DROP_PCT=-2.0

# === Web 服务配置 ===
WEB_HOST=0.0.0.0
WEB_PORT=5000

# === 数据库配置 (SQLite) ===
SQLITE_PATH=./data/fund.db

# === 通知配置（全部可选，配置了就会推送） ===

# 企业微信 Webhook
# WECHAT_WEBHOOK_URL=

# 飞书 Webhook
# FEISHU_WEBHOOK_URL=

# Telegram Bot
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# TELEGRAM_API_BASE_URL=https://api.telegram.org

# 邮件通知（SMTP）
# EMAIL_SENDER=your@qq.com
# EMAIL_PASSWORD=your_smtp_password
# EMAIL_RECEIVERS=receiver1@qq.com,receiver2@qq.com

# 自定义 Webhook（支持钉钉、Slack、Discord 等）
# CUSTOM_WEBHOOK_URLS=

# === 网络代理 ===
# "none" = 强制直连（忽略系统代理）
# 具体地址 = 走指定代理，如 http://127.0.0.1:7890
# 留空 = 跟随系统
PROXY_URL=none

# === 日志配置 ===
LOG_DIR=./logs
LOG_LEVEL=INFO

# === 调试模式 ===
DEBUG=false
